{
  "version": "1.0.0",
  "branches": {
    "main": {
      "description": "Branch de produção",
      "protection": {
        "required_approving_review_count": 2,
        "enforce_admins": true,
        "required_status_checks": {
          "strict": true,
          "contexts": [
            "ci",
            "tests",
            "coverage"
          ]
        },
        "require_code_owner_reviews": true,
        "allowed_teams": [
          "maintainers",
          "senior-developers"
        ]
      }
    },
    "develop": {
      "description": "Branch de integração",
      "protection": {
        "required_approving_review_count": 1,
        "enforce_admins": false,
        "required_status_checks": {
          "strict": false,
          "contexts": [
            "ci",
            "tests"
          ]
        },
        "require_code_owner_reviews": false,
        "allowed_teams": [
          "developers",
          "maintainers"
        ]
      }
    }
  },
  "branch_types": {
    "feature": {
      "prefix": "feature/",
      "description": "Novas funcionalidades",
      "target": "develop",
      "example": "feature/user-authentication"
    },
    "bugfix": {
      "prefix": "bugfix/",
      "description": "Correções de bugs",
      "target": "develop",
      "example": "bugfix/login-validation-error"
    },
    "hotfix": {
      "prefix": "hotfix/",
      "description": "Correções críticas em produção",
      "target": "main",
      "example": "hotfix/security-patch"
    },
    "release": {
      "prefix": "release/",
      "description": "Preparação de releases",
      "target": "main",
      "example": "release/v1.2.0"
    }
  },
  "commit_convention": "conventional_commits",
  "created_at": "2026-04-21T19:31:52.415Z",
  "repository": "quoteIAmanager"
}